# ============================================
# AIVA Frontend Environment Configuration
# ============================================

# The URL of your deployed AIVA Backend (Render/Railway)
# For local development, use: http://localhost:5000
BACKEND_URL=https://your-aiva-backend.onrender.com

# Your custom AIVA security key for handshake authentication
# This MUST match the 'API_KEY' set in your Backend environment variables
NEXT_PUBLIC_API_KEY=your_secret_aiva_key_here
