# ============================================
# 🤖 AIVA Backend Environment Configuration
# Example File - Copy to .env and fill in values
# ============================================

# Server Port
PORT=5000

# ============================================
# 🧠 AI Brain Configuration
# ============================================

# Primary Engine: Gemini 2.5 Flash
# 1. Go to: https://aistudio.google.com/
# 2. Sign in with your Google Account
# 3. Click "Get API key" in the left sidebar
# 4. Create an API key in a new or existing project
GEMINI_API_KEY=your_gemini_key_here

# Secondary Fallback Engine: Groq Llama 3.3
# 1. Go to: https://console.groq.com/keys
# 2. Create an account and log in
# 3. Click "Create API Key" and copy the generated key
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# 🌐 Web Search and Context Fallbacks
# ============================================

# Tertiary Search Fallback: Tavily AI
# 1. Go to: https://tavily.com/
# 2. Sign up for a free developer account
# 3. Navigate to the API Dashboard and copy your API key
TVLY_API_KEY=your_tavily_key_here

# Quaternary Search Fallback: Google Programmable Search Engine
# - To get GOOGLE_SEARCH_API_KEY:
#   1. Go to: https://developers.google.com/custom-search/v1/introduction
#   2. Click "Get a Key" and follow the prompts to create a Google Cloud Project
# - To get GOOGLE_SEARCH_CX (Search Engine ID):
#   1. Go to: https://programmablesearchengine.google.com/controlpanel/all
#   2. Click "Add" to create a new search engine
#   3. Name it, select "Search the entire web"
#   4. After creation, copy your "Search engine ID" (CX)
GOOGLE_SEARCH_API_KEY=your_google_search_key_here
GOOGLE_SEARCH_CX=your_google_cx_here

# ============================================
# ⛈️ Weather APIs (Dual Fallback System)
# ============================================

# Primary Weather API: WeatherAPI.com
# 1. Go to: https://www.weatherapi.com/
# 2. Sign up for a free account and check your dashboard
WEATHER_API_KEY=your_weatherapi_key_here

# Fallback Weather API: OpenWeatherMap
# 1. Go to: https://openweathermap.org/api
# 2. Sign up, navigate to the "My API Keys" tab 
OPENWEATHER_API_KEY=your_openweather_key_here

# ============================================
# 🏏 Live Sports & 📰 News APIs
# ============================================

# Cricket Match Scores: CricketData.org
# 1. Go to: https://cricketdata.org/
# 2. Register for a free account to view your API key
CRICKET_API_KEY=your_cricket_key_here

# Football/Soccer Match Scores: API-Football
# 1. Go to: https://dashboard.api-football.com/
# 2. Register, log in, and view your API key on the Account Dashboard
SPORTS_API_KEY=your_sports_key_here

# News Headlines: GNews.io
# 1. Go to: https://gnews.io/
# 2. Create an account, and your default API key is displayed immediately
NEWS_API_KEY=your_gnews_key_here
