# ============================================
# AIVA Backend Environment Configuration
# Example File - Copy to .env and fill in values
# ============================================

# Server Port
PORT=5000

# Groq API Key (for Llama 3.3 70B AI features)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Weather APIs (Fallback system)
# Get your keys at: https://openweathermap.org/api and https://www.weatherapi.com/
OPENWEATHER_API_KEY=your_openweather_key_here
WEATHER_API_KEY=your_weatherapi_key_here

# Live Sports APIs
# Get your keys at: https://cricketdata.org/ and https://www.api-football.com/
CRICKET_API_KEY=your_cricket_key_here
SPORTS_API_KEY=your_sports_key_here

# News API
# Get your key at: https://gnews.io/
NEWS_API_KEY=your_gnews_key_here

# Gemini API (Primary AI Engine)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_key_here
